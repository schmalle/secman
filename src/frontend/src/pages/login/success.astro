---
// src/pages/login/success.astro
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Successful - SecMan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .spinner-border {
            width: 3rem;
            height: 3rem;
        }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card">
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <img src="/SecManLogo.png" alt="SecMan" height="90" class="mb-3" />
                            <h3 class="card-title">Login Successful</h3>
                        </div>
                        
                        <div id="login-spinner" class="mb-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 text-muted">Redirecting you to the application...</p>
                        </div>
                        <div id="login-error" class="mb-4" style="display: none;">
                            <div class="alert alert-danger" role="alert">
                                <strong>Login Error:</strong> <span id="login-error-message"></span>
                            </div>
                            <a href="/login" class="btn btn-primary">Back to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showError(message) {
            var spinner = document.getElementById('login-spinner');
            var errorDiv = document.getElementById('login-error');
            var errorMsg = document.getElementById('login-error-message');
            if (spinner) spinner.style.display = 'none';
            if (errorDiv) errorDiv.style.display = 'block';
            if (errorMsg) errorMsg.textContent = message;
        }

        // Extract URL parameters
        // Note: JWT token is delivered solely via HttpOnly cookie (secman_auth) set by backend.
        // Only user metadata is passed in the URL for client-side state.
        var urlParams = new URLSearchParams(window.location.search);
        var userJson = urlParams.get('user');

        if (userJson) {
            try {
                // Decode and parse user data
                var userData = JSON.parse(decodeURIComponent(userJson));

                // Clean up any legacy token storage from previous versions
                localStorage.removeItem('authToken');
                document.cookie = 'authToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';

                // Store user metadata only (non-sensitive, for UI display and role checks)
                // Authentication is handled entirely via the HttpOnly secman_auth cookie
                localStorage.setItem('user', JSON.stringify(userData));

                // Set global user state for Header component
                window.currentUser = userData;
                window.dispatchEvent(new CustomEvent('userLoaded'));

                // Clean sensitive data from URL before redirect (prevents token in browser history)
                window.history.replaceState({}, '', '/login/success');

                // Verify the auth cookie is working before redirecting
                fetch('/api/auth/status', { credentials: 'include' })
                    .then(function(response) {
                        if (response.ok) {
                            window.location.href = '/';
                        } else {
                            console.error('Auth verification failed, status:', response.status, 'statusText:', response.statusText);
                            showError('Authentication cookie was not set properly (HTTP ' + response.status + '). Please try logging in again.');
                        }
                    })
                    .catch(function(err) {
                        console.error('Auth verification request failed:', err);
                        // Network error - try redirecting anyway, the cookie might still work
                        window.location.href = '/';
                    });

            } catch (error) {
                console.error('Error processing login success:', error);
                showError('Login succeeded, but there was an error processing your data. Please try again.');
            }
        } else {
            console.error('Missing user data in OAuth callback');
            showError('Login data was not received. Please try logging in again.');
        }
    </script>
</body>
</html>