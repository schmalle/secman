---
// src/pages/login/success.astro
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Successful - SecMan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .spinner-border {
            width: 3rem;
            height: 3rem;
        }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card">
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <img src="/SecManLogo.png" alt="SecMan" height="90" class="mb-3" />
                            <h3 class="card-title">Login Successful</h3>
                        </div>
                        
                        <div id="login-spinner" class="mb-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 text-muted">Redirecting you to the application...</p>
                        </div>
                        <div id="login-error" class="mb-4" style="display: none;">
                            <div class="alert alert-danger" role="alert">
                                <strong>Login Error:</strong> <span id="login-error-message"></span>
                            </div>
                            <a href="/login" class="btn btn-primary">Back to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showError(message) {
            var spinner = document.getElementById('login-spinner');
            var errorDiv = document.getElementById('login-error');
            var errorMsg = document.getElementById('login-error-message');
            if (spinner) spinner.style.display = 'none';
            if (errorDiv) errorDiv.style.display = 'block';
            if (errorMsg) errorMsg.textContent = message;
        }

        // Clean up any legacy token storage from previous versions
        localStorage.removeItem('authToken');
        document.cookie = 'authToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';

        // Security: User metadata is no longer passed in the URL to prevent PII exposure
        // in browser history, access logs, and Referer headers.
        // Instead, fetch user data from the authenticated /api/auth/status endpoint
        // using the HttpOnly cookie set by the backend during OAuth callback.
        fetch('/api/auth/status', {
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include'
        })
            .then(function(response) {
                if (response.ok) {
                    return response.json();
                }
                throw new Error('HTTP ' + response.status);
            })
            .then(function(userData) {
                // Store user metadata for UI display and role checks
                sessionStorage.setItem('user', JSON.stringify(userData));

                // Set global user state for Header component
                window.currentUser = userData;
                window.dispatchEvent(new CustomEvent('userLoaded'));

                window.location.href = '/';
            })
            .catch(function(err) {
                console.error('Auth verification failed:', err);
                showError('Authentication cookie was not set properly. Please try logging in again.');
            });
    </script>
</body>
</html>