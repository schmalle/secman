---
import Layout from '../../layouts/Layout.astro';
import Ec2ComplianceDashboard from '../../components/admin/Ec2ComplianceDashboard.tsx';
---

<Layout title="EC2 Compliance Tracking - Admin">
  <div class="container-fluid p-4">
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2>EC2 Compliance Tracking</h2>
            <p class="text-muted mb-0">
              Track vulnerability compliance status changes across all assets
            </p>
          </div>
          <a href="/admin" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>
            Back to Admin
          </a>
        </div>
      </div>
    </div>

    <Ec2ComplianceDashboard client:load />
  </div>
</Layout>
