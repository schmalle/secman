---
import Layout from '../../../layouts/Layout.astro';
import Ec2ComplianceDetail from '../../../components/admin/Ec2ComplianceDetail.tsx';

const { id } = Astro.params;
---

<Layout title="Asset Compliance History - Admin">
  <div class="container-fluid p-4">
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2>Asset Compliance History</h2>
            <p class="text-muted mb-0">
              Compliance status timeline for this asset
            </p>
          </div>
          <a href="/admin/ec2-compliance" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>
            Back to Overview
          </a>
        </div>
      </div>
    </div>

    <Ec2ComplianceDetail client:load assetId={Number(id)} />
  </div>
</Layout>
