---
import Layout from '../../layouts/Layout.astro';
import AdminAddSystem from '../../components/admin/AdminAddSystem';
---

<Layout title="Admin - Add System & Vulnerability">
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <h2 class="mb-4">
                    <i class="bi bi-plus-circle-fill text-primary me-2"></i>
                    Add System & Vulnerability
                </h2>
                <p class="text-muted">
                    Manually add systems (assets) and vulnerabilities. Assets created here are immediately
                    visible to the assigned owner. Vulnerabilities will auto-create the asset if it doesn't exist.
                </p>
            </div>
        </div>

        <AdminAddSystem client:load />

        <div class="mt-4">
            <a href="/admin" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>
                Back to Admin
            </a>
        </div>
    </div>
</Layout>
