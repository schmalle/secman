# adread.env.local — local secrets for import-workgroups-noproton.sh
#
# Copy this file to adread.env.local and fill in real values.
# adread.env.local is gitignored — never commit it.

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

SECMAN_BACKEND_URL=http://localhost:8080
SECMAN_ADMIN_NAME=admin
SECMAN_ADMIN_PASS=changeme
